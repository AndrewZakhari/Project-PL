<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.inventory.pl_project.controllers.ProductController">

    <top>
        <Label text="Product Management" style="-fx-font-size: 24px; -fx-font-weight: bold;">
            <BorderPane.margin>
                <Insets top="10.0" bottom="10.0" left="10.0"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <SplitPane dividerPositions="0.6">
            <!-- Product Table -->
            <VBox spacing="10">
                <padding>
                    <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                </padding>

                <Label text="Product List" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="100"/>
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120"/>
                        <TableColumn fx:id="priceColumn" text="Price" prefWidth="80"/>
                        <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="80"/>
                        <TableColumn fx:id="expirationColumn" text="Expiration" prefWidth="100"/>
                    </columns>
                </TableView>

                <!-- Search Section -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="searchTypeComboBox" prefWidth="120"/>
                    <TextField fx:id="searchField" promptText="Search..." prefWidth="200"/>
                    <DatePicker fx:id="searchStartDate" promptText="Start Date" visible="false"/>
                    <DatePicker fx:id="searchEndDate" promptText="End Date" visible="false"/>
                    <Button text="Search" onAction="#handleSearch"/>
                    <Button text="Reset" onAction="#handleReset"/>
                    <Button fx:id="checkExpirationBtn" text="Check Expiration"
                            onAction="#handleCheckExpiration"
                            style="-fx-background-color: #e67e22; -fx-text-fill: white;"/>
                </HBox>
            </VBox>

            <!-- Product Form -->
            <VBox spacing="15">
                <padding>
                    <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                </padding>

                <Label text="Product Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <GridPane hgap="10" vgap="10">
                    <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>

                    <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="categoryComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="200"/>

                    <Label text="Price:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="priceField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Quantity:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="quantityField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                    <Label text="Expiration Date:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <DatePicker fx:id="expirationDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="200"/>

                    <Label text="Supplier ID:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <TextField fx:id="supplierField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                </GridPane>

                <HBox spacing="10" alignment="CENTER">
                    <Button text="Add Product" onAction="#handleAddProduct"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white;" prefWidth="120"/>
                    <Button text="Update" onAction="#handleUpdateProduct"
                            style="-fx-background-color: #3498db; -fx-text-fill: white;" prefWidth="120"/>
                    <Button text="Delete" onAction="#handleDeleteProduct"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;" prefWidth="120"/>
                </HBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>