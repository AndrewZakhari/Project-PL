<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.inventory.pl_project.controllers.AdminController">

    <top>
        <Label text="Admin Module" style="-fx-font-size: 24px; -fx-font-weight: bold;">
            <BorderPane.margin>
                <Insets top="10.0" bottom="10.0" left="10.0"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- CATEGORY TAB -->
            <Tab text="Categories">
                <SplitPane dividerPositions="0.6">
                    <!-- Category Table -->
                    <VBox spacing="10">
                        <padding>
                            <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                        </padding>

                        <Label text="Category List" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="catIdColumn" text="ID" prefWidth="150"/>
                                <TableColumn fx:id="catNameColumn" text="Name" prefWidth="200"/>
                                <TableColumn fx:id="catDescColumn" text="Description" prefWidth="250"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Category Form -->
                    <VBox spacing="15">
                        <padding>
                            <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                        </padding>

                        <Label text="Category Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <GridPane hgap="10" vgap="15">
                            <Label text="Category Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <TextField fx:id="categoryNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                       prefWidth="250" promptText="Enter category name"/>

                            <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextArea fx:id="categoryDescField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                      prefWidth="250" prefHeight="80" promptText="Enter description"/>
                        </GridPane>

                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Add Category" onAction="#handleAddCategory"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white;" prefWidth="130"/>
                            <Button text="Update" onAction="#handleUpdateCategory"
                                    style="-fx-background-color: #3498db; -fx-text-fill: white;" prefWidth="130"/>
                            <Button text="Delete" onAction="#handleDeleteCategory"
                                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;" prefWidth="130"/>
                        </HBox>
                    </VBox>
                </SplitPane>
            </Tab>

            <!-- SUPPLIER TAB -->
            <Tab text="Suppliers">
                <SplitPane dividerPositions="0.6">
                    <!-- Supplier Table -->
                    <VBox spacing="10">
                        <padding>
                            <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                        </padding>

                        <Label text="Supplier List" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="suppIdColumn" text="ID" prefWidth="120"/>
                                <TableColumn fx:id="suppNameColumn" text="Name" prefWidth="150"/>
                                <TableColumn fx:id="suppEmailColumn" text="Email" prefWidth="180"/>
                                <TableColumn fx:id="suppPhoneColumn" text="Phone" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Supplier Form -->
                    <VBox spacing="15">
                        <padding>
                            <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                        </padding>

                        <Label text="Supplier Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <GridPane hgap="10" vgap="10">
                            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <TextField fx:id="supplierNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                       prefWidth="250" promptText="Supplier name"/>

                            <Label text="Contact Person:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="supplierContactField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                       prefWidth="250" promptText="Contact person"/>

                            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <TextField fx:id="supplierEmailField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                       prefWidth="250" promptText="email@example.com"/>

                            <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <TextField fx:id="supplierPhoneField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                       prefWidth="250" promptText="Phone number"/>

                            <Label text="Address:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <TextArea fx:id="supplierAddressField" GridPane.columnIndex="1" GridPane.rowIndex="4"
                                      prefWidth="250" prefHeight="60" promptText="Full address"/>
                        </GridPane>

                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Add Supplier" onAction="#handleAddSupplier"
                                    style="-fx-background-color: #27ae60; -fx-text-fill: white;" prefWidth="130"/>
                            <Button text="Update" onAction="#handleUpdateSupplier"
                                    style="-fx-background-color: #3498db; -fx-text-fill: white;" prefWidth="130"/>
                            <Button text="Delete" onAction="#handleDeleteSupplier"
                                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;" prefWidth="130"/>
                        </HBox>
                    </VBox>
                </SplitPane>
            </Tab>

            <!-- OFFERS TAB -->
            <Tab text="Offers">
                <VBox spacing="20">
                    <padding>
                        <Insets top="20.0" bottom="20.0" left="20.0" right="20.0"/>
                    </padding>

                    <Label text="Add Product Offer" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <GridPane hgap="15" vgap="15">
                        <Label text="Product:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="offerProductComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0"
                                  prefWidth="300" promptText="Select product"/>

                        <Label text="Discount (%):" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="discountField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                   prefWidth="300" promptText="e.g., 20"/>

                        <Label text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <DatePicker fx:id="offerStartDate" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                    prefWidth="300"/>

                        <Label text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <DatePicker fx:id="offerEndDate" GridPane.columnIndex="1" GridPane.rowIndex="3"
                                    prefWidth="300"/>
                    </GridPane>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Add Offer" onAction="#handleAddOffer"
                                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 14px;"
                                prefWidth="200" prefHeight="35"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- REPORTS TAB -->
            <Tab text="Reports & Statistics">
                <VBox spacing="15">
                    <padding>
                        <Insets top="20.0" bottom="20.0" left="20.0" right="20.0"/>
                    </padding>

                    <Label text="Generate Reports" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="Report Type:"/>
                        <ComboBox fx:id="reportTypeComboBox" prefWidth="200"/>

                        <Label text="Start Date:"/>
                        <DatePicker fx:id="reportStartDate" prefWidth="150"/>

                        <Label text="End Date:"/>
                        <DatePicker fx:id="reportEndDate" prefWidth="150"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Generate Report" onAction="#handleGenerateReport"
                                style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px;"
                                prefWidth="150"/>
                        <Button text="Clear" onAction="#handleClearReport"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 14px;"
                                prefWidth="150"/>
                    </HBox>

                    <Label text="Report Output:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <TextArea fx:id="reportTextArea" VBox.vgrow="ALWAYS" editable="false"
                              style="-fx-font-family: 'Courier New'; -fx-font-size: 12px;"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>