<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.inventory.pl_project.controllers.MainController"
      style="-fx-background-color: #f4f4f4;">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
    </padding>

    <Label text="Inventory Management System" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Select a module to continue" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>

    <HBox alignment="CENTER" spacing="20.0">
        <Button fx:id="productModuleBtn" text="Product Module" onAction="#openProductModule"
                prefWidth="200" prefHeight="100"
                style="-fx-font-size: 16px; -fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 10;"/>

        <Button fx:id="adminModuleBtn" text="Admin Module" onAction="#openAdminModule"
                prefWidth="200" prefHeight="100"
                style="-fx-font-size: 16px; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10;"/>

        <Button fx:id="clientModuleBtn" text="Client Module" onAction="#openClientModule"
                prefWidth="200" prefHeight="100"
                style="-fx-font-size: 16px; -fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 10;"/>
    </HBox>
</VBox>